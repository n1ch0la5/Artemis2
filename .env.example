# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Settings → API → Project URL and anon/public key
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── NASA AROW (optional) ──────────────────────────────────────────────────────
# If NASA publishes a public AROW endpoint, add it here.
# The /api/arow Netlify function will proxy it to avoid CORS.
# Leave blank to use calculated fallback values.
NASA_AROW_URL=
